#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
posts_dir="$repo_root/_posts"
assets_img_dir="$repo_root/assets/img"
mkdir -p "$posts_dir"
mkdir -p "$assets_img_dir"

prompt() {
  local var_name="$1"
  local text="$2"
  local default="${3:-}"
  local value=""
  if [[ -n "$default" ]]; then
    read -r -p "$text [$default]: " value
    value="${value:-$default}"
  else
    read -r -p "$text: " value
  fi
  printf -v "$var_name" '%s' "$value"
}

slugify() {
  echo "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

urlencode() {
  python3 - "$1" <<'PY'
import sys, urllib.parse
print(urllib.parse.quote(sys.argv[1]))
PY
}

download_header_image() {
  local query="$1"
  local output_path="$2"
  local encoded_query=""
  encoded_query="$(urlencode "$query")"

  # Use multiple free providers (no API keys) for robustness.
  # 1) Unsplash source (often good, sometimes 503)
  # 2) LoremFlickr (tag-based; sometimes blocks)
  # 3) Picsum (random fallback)
  local -a urls=(
    "https://source.unsplash.com/1600x900/?${encoded_query}"
    "https://loremflickr.com/1600/900/${encoded_query}"
    "https://picsum.photos/1600/900.jpg"
  )

  local url=""
  for url in "${urls[@]}"; do
    if curl -fsSL \
      --retry 3 \
      --retry-all-errors \
      --retry-delay 1 \
      --connect-timeout 10 \
      --max-time 30 \
      -o "$output_path" \
      "$url" 2>/dev/null; then
      return 0
    fi
  done

  return 1
}

today="$(date +%F)"

title=""
date_ymd=""
tags_csv=""
description=""
permalink=""
header_image_query=""
layout="post"

prompt title "Title"
prompt date_ymd "Date (YYYY-MM-DD)" "$today"
prompt tags_csv "Tags (comma-separated, optional)" ""
prompt description "Description (optional, used for meta/OG)" ""
prompt permalink "Permalink (optional, e.g. /my-post.html or /2026/03/17/my-post/)" ""
prompt header_image_query "Header image topic (optional, downloads an image)" ""

slug="$(slugify "$title")"
filename="${date_ymd}-${slug}.md"
path="${posts_dir}/${filename}"

if [[ -e "$path" ]]; then
  echo "Error: already exists: $path" >&2
  exit 1
fi

tags_yaml="[]"
if [[ -n "${tags_csv// /}" ]]; then
  IFS=',' read -r -a tags_arr <<< "$tags_csv"
  cleaned=()
  for t in "${tags_arr[@]}"; do
    tt="$(echo "$t" | sed -E 's/^[[:space:]]+|[[:space:]]+$//g')"
    [[ -n "$tt" ]] && cleaned+=("$tt")
  done
  if [[ "${#cleaned[@]}" -gt 0 ]]; then
    tags_yaml="["
    for i in "${!cleaned[@]}"; do
      (( i > 0 )) && tags_yaml+=", "
      tags_yaml+="\"${cleaned[$i]//\"/\\\"}\""
    done
    tags_yaml+="]"
  fi
fi

og_image=""
header_image=""
if [[ -n "${header_image_query// /}" ]]; then
  if command -v curl >/dev/null 2>&1 && command -v python3 >/dev/null 2>&1; then
    post_asset_dir="$assets_img_dir/$slug"
    mkdir -p "$post_asset_dir"

    header_image_path="$post_asset_dir/header.jpg"
    if download_header_image "$header_image_query" "$header_image_path"; then
      og_image="/assets/img/$slug/header.jpg"
      header_image="/assets/img/$slug/header.jpg"
      echo "Downloaded header image: $header_image_path" >&2
    else
      echo "Warning: failed to download header image; continuing without it." >&2
    fi
  else
    echo "Warning: curl/python3 not available; skipping header image download." >&2
  fi
fi

{
  echo "---"
  echo "layout: ${layout}"
  echo "title: \"${title//\"/\\\"}\""
  echo "date: ${date_ymd}"
  echo "tags: ${tags_yaml}"
  [[ -n "$description" ]] && echo "description: \"${description//\"/\\\"}\""
  [[ -n "$permalink" ]] && echo "permalink: ${permalink}"
  [[ -n "$og_image" ]] && echo "og_image: ${og_image}"
  [[ -n "$header_image" ]] && echo "header_image: ${header_image}"
  echo "---"
  echo
  echo "Write here."
  echo
} > "$path"

echo "Created: $path"
echo "Next:"
echo "  bundle exec jekyll serve"

