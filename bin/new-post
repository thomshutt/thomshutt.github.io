#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
posts_dir="$repo_root/_posts"
mkdir -p "$posts_dir"

prompt() {
  local var_name="$1"
  local text="$2"
  local default="${3:-}"
  local value=""
  if [[ -n "$default" ]]; then
    read -r -p "$text [$default]: " value
    value="${value:-$default}"
  else
    read -r -p "$text: " value
  fi
  printf -v "$var_name" '%s' "$value"
}

slugify() {
  echo "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

today="$(date +%F)"

title=""
date_ymd=""
tags_csv=""
description=""
permalink=""
layout="post"

prompt title "Title"
prompt date_ymd "Date (YYYY-MM-DD)" "$today"
prompt tags_csv "Tags (comma-separated, optional)" ""
prompt description "Description (optional, used for meta/OG)" ""
prompt permalink "Permalink (optional, e.g. /my-post.html or /2026/03/17/my-post/)" ""

slug="$(slugify "$title")"
filename="${date_ymd}-${slug}.md"
path="${posts_dir}/${filename}"

if [[ -e "$path" ]]; then
  echo "Error: already exists: $path" >&2
  exit 1
fi

tags_yaml="[]"
if [[ -n "${tags_csv// /}" ]]; then
  IFS=',' read -r -a tags_arr <<< "$tags_csv"
  cleaned=()
  for t in "${tags_arr[@]}"; do
    tt="$(echo "$t" | sed -E 's/^[[:space:]]+|[[:space:]]+$//g')"
    [[ -n "$tt" ]] && cleaned+=("\"$tt\"")
  done
  if [[ "${#cleaned[@]}" -gt 0 ]]; then
    tags_yaml="[${cleaned[*]}]"
    tags_yaml="${tags_yaml//\" /\", \"}"
  fi
fi

{
  echo "---"
  echo "layout: ${layout}"
  echo "title: \"${title//\"/\\\"}\""
  echo "date: ${date_ymd}"
  echo "tags: ${tags_yaml}"
  [[ -n "$description" ]] && echo "description: \"${description//\"/\\\"}\""
  [[ -n "$permalink" ]] && echo "permalink: ${permalink}"
  echo "---"
  echo
  echo "Write here."
  echo
} > "$path"

echo "Created: $path"
echo "Next:"
echo "  bundle exec jekyll serve"

